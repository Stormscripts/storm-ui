local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local StormUI = {}

-- Função auxiliar para criar cantos arredondados
local function applyRoundedCorners(gui, radius)
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, radius)
	corner.Parent = gui
end

-- Função para aplicar gradiente (modo escuro)
local function applyGradient(gui)
	local gradient = Instance.new("UIGradient")
	gradient.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromRGB(45,45,45)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(35,35,35))
	})
	gradient.Parent = gui
end

function StormUI:CreateWindow(title)
	local ScreenGui = Instance.new("ScreenGui")
	ScreenGui.Name = "StormUI"
	ScreenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

	-- Frame principal (janela)
	local MainFrame = Instance.new("Frame")
	MainFrame.Size = UDim2.new(0, 220, 0, 30) -- altura inicial
	MainFrame.Position = UDim2.new(0.5, -110, 0.5, -150)
	MainFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
	MainFrame.BorderSizePixel = 0
	MainFrame.Active = true
	MainFrame.Parent = ScreenGui
	applyRoundedCorners(MainFrame, 8)
	applyGradient(MainFrame)

	-- Sombra simulada (frame atrás com leve offset)
	local shadow = Instance.new("Frame")
	shadow.Size = UDim2.new(1, 0, 1, 0)
	shadow.Position = UDim2.new(0, 3, 0, 3)
	shadow.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
	shadow.BorderSizePixel = 0
	shadow.ZIndex = 0
	applyRoundedCorners(shadow, 8)
	shadow.Parent = MainFrame
	shadow.BackgroundTransparency = 0.5

	-- Barra de título
	local TitleBar = Instance.new("Frame")
	TitleBar.Size = UDim2.new(1, 0, 0, 32)
	TitleBar.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
	TitleBar.BorderSizePixel = 0
	applyRoundedCorners(TitleBar, 8)
	TitleBar.Parent = MainFrame

	local titleGradient = Instance.new("UIGradient")
	titleGradient.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 170, 255)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 100, 200))
	})
	titleGradient.Parent = TitleBar

	local TitleLabel = Instance.new("TextLabel")
	TitleLabel.Size = UDim2.new(1, -35, 1, 0)
	TitleLabel.Position = UDim2.new(0, 10, 0, 0)
	TitleLabel.BackgroundTransparency = 1
	TitleLabel.Text = title
	TitleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	TitleLabel.Font = Enum.Font.GothamBold
	TitleLabel.TextSize = 15
	TitleLabel.TextXAlignment = Enum.TextXAlignment.Left
	TitleLabel.Parent = TitleBar

	-- Botão de minimizar ( − )
	local MinimizeButton = Instance.new("TextButton")
	MinimizeButton.Size = UDim2.new(0, 30, 0, 30)
	MinimizeButton.Position = UDim2.new(1, -30, 0, 1)
	MinimizeButton.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
	MinimizeButton.BorderSizePixel = 0
	MinimizeButton.Text = "−"
	MinimizeButton.TextColor3 = Color3.fromRGB(255, 255, 255)
	MinimizeButton.Font = Enum.Font.GothamBold
	MinimizeButton.TextSize = 20
	applyRoundedCorners(MinimizeButton, 6)
	MinimizeButton.Parent = TitleBar

	-- Container rolável para elementos
	local Container = Instance.new("ScrollingFrame")
	Container.Size = UDim2.new(1, 0, 0, 0) -- altura será controlada
	Container.Position = UDim2.new(0, 0, 0, 32)
	Container.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
	Container.BorderSizePixel = 0
	Container.ScrollBarThickness = 4
	Container.ScrollBarImageColor3 = Color3.fromRGB(0, 170, 255)
	Container.CanvasSize = UDim2.new(0, 0, 0, 0)
	Container.AutomaticCanvasSize = Enum.AutomaticSize.Y
	Container.Parent = MainFrame
	applyRoundedCorners(Container, 4)

	local UIListLayout = Instance.new("UIListLayout")
	UIListLayout.Padding = UDim.new(0, 4)
	UIListLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	UIListLayout.SortOrder = Enum.SortOrder.LayoutOrder
	UIListLayout.Parent = Container

	local Window = {}
	Window.MainFrame = MainFrame
	Window.Container = Container
	Window.Minimized = false
	Window.TotalHeight = 0 -- altura acumulada dos elementos (será usada para cálculo)

	-- Função para atualizar altura da janela com base no conteúdo
	local function updateMainFrameHeight()
		if not Window.Minimized then
			local contentHeight = Container.AbsoluteCanvasSize.Y
			local maxHeight = 400 -- altura máxima antes de scroll
			local displayHeight = math.min(contentHeight, maxHeight)
			Container.Size = UDim2.new(1, 0, 0, displayHeight)
			MainFrame.Size = UDim2.new(0, 220, 0, 32 + displayHeight)
		else
			MainFrame.Size = UDim2.new(0, 220, 0, 32)
		end
	end

	Container:GetPropertyChangedSignal("AbsoluteCanvasSize"):Connect(updateMainFrameHeight)

	-- Minimizar / expandir
	MinimizeButton.MouseButton1Click:Connect(function()
		Window.Minimized = not Window.Minimized
		Container.Visible = not Window.Minimized
		updateMainFrameHeight()
	end)

	-- Tornar a janela arrastável (PC e toque)
	local dragging = false
	local dragStartPos = nil
	local startFramePos = nil

	TitleBar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStartPos = input.Position
			startFramePos = MainFrame.Position
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragStartPos
			MainFrame.Position = UDim2.new(
				startFramePos.X.Scale,
				startFramePos.X.Offset + delta.X,
				startFramePos.Y.Scale,
				startFramePos.Y.Offset + delta.Y
			)
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)

	-- ===== SISTEMA DE SEÇÕES =====
	function Window:AddSection(name)
		local SectionFrame = Instance.new("Frame")
		SectionFrame.Size = UDim2.new(1, -10, 0, 28)
		SectionFrame.BackgroundColor3 = Color3.fromRGB(38, 38, 38)
		SectionFrame.BorderSizePixel = 0
		applyRoundedCorners(SectionFrame, 5)
		SectionFrame.Parent = Container

		local sectionLabel = Instance.new("TextLabel")
		sectionLabel.Size = UDim2.new(1, 0, 1, 0)
		sectionLabel.Position = UDim2.new(0, 8, 0, 0)
		sectionLabel.BackgroundTransparency = 1
		sectionLabel.Text = name
		sectionLabel.TextColor3 = Color3.fromRGB(0, 170, 255)
		sectionLabel.Font = Enum.Font.GothamSemibold
		sectionLabel.TextSize = 14
		sectionLabel.TextXAlignment = Enum.TextXAlignment.Left
		sectionLabel.Parent = SectionFrame

		local Section = {}
		Section.Frame = SectionFrame
		Section.Parent = Container

		-- Métodos da seção (redirecionam para os métodos da Window, mas adicionam dentro do Container normalmente, ou uma alternativa: inserir elementos logo após o frame da seção)
		-- Para manter a ordem, vamos inserir após a seção
		local lastChild = SectionFrame
		local function addElement(element)
			element.LayoutOrder = lastChild.LayoutOrder + 1
			element.Parent = Container
			lastChild = element
			updateMainFrameHeight()
			return element
		end

		Section.AddLabel = function(text)
			local label = Instance.new("TextLabel")
			label.Size = UDim2.new(1, -10, 0, 18)
			label.BackgroundTransparency = 1
			label.Text = text
			label.TextColor3 = Color3.fromRGB(220, 220, 220)
			label.Font = Enum.Font.Gotham
			label.TextSize = 12
			label.TextXAlignment = Enum.TextXAlignment.Left
			label.Parent = Container
			label.LayoutOrder = lastChild.LayoutOrder + 1
			lastChild = label
			updateMainFrameHeight()
			return label
		end

		Section.AddButton = function(text, callback)
			local btn = Instance.new("TextButton")
			btn.Size = UDim2.new(1, -10, 0, 26)
			btn.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
			btn.BorderSizePixel = 0
			btn.Text = text
			btn.TextColor3 = Color3.fromRGB(255, 255, 255)
			btn.Font = Enum.Font.GothamSemibold
			btn.TextSize = 14
			applyRoundedCorners(btn, 6)
			local hoverGradient = Instance.new("UIGradient")
			hoverGradient.Color = ColorSequence.new({
				ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 130, 220)),
				ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 100, 200))
			})
			hoverGradient.Parent = btn
			btn.Parent = Container
			btn.LayoutOrder = lastChild.LayoutOrder + 1
			lastChild = btn
			btn.MouseButton1Click:Connect(callback)
			updateMainFrameHeight()
			return btn
		end

		Section.AddToggle = function(text, default, callback)
			local frame = Instance.new("Frame")
			frame.Size = UDim2.new(1, -10, 0, 26)
			frame.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
			frame.BorderSizePixel = 0
			applyRoundedCorners(frame, 5)
			frame.Parent = Container
			frame.LayoutOrder = lastChild.LayoutOrder + 1
			lastChild = frame

			local label = Instance.new("TextLabel")
			label.Size = UDim2.new(1, -30, 1, 0)
			label.Position = UDim2.new(0, 6, 0, 0)
			label.BackgroundTransparency = 1
			label.Text = text
			label.TextColor3 = Color3.fromRGB(240, 240, 240)
			label.Font = Enum.Font.Gotham
			label.TextSize = 13
			label.TextXAlignment = Enum.TextXAlignment.Left
			label.Parent = frame

			local toggleBtn = Instance.new("TextButton")
			toggleBtn.Size = UDim2.new(0, 22, 0, 22)
			toggleBtn.Position = UDim2.new(1, -24, 0.5, -11)
			toggleBtn.BackgroundColor3 = default and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(200, 30, 30)
			toggleBtn.BorderSizePixel = 0
			toggleBtn.Text = ""
			applyRoundedCorners(toggleBtn, 11)
			toggleBtn.Parent = frame

			local state = default
			toggleBtn.MouseButton1Click:Connect(function()
				state = not state
				toggleBtn.BackgroundColor3 = state and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(200, 30, 30)
				callback(state)
			end)
			updateMainFrameHeight()
			return frame
		end

		Section.AddSlider = function(text, min, max, default, callback)
			local frame = Instance.new("Frame")
			frame.Size = UDim2.new(1, -10, 0, 36)
			frame.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
			frame.BorderSizePixel = 0
			applyRoundedCorners(frame, 5)
			frame.Parent = Container
			frame.LayoutOrder = lastChild.LayoutOrder + 1
			lastChild = frame

			local label = Instance.new("TextLabel")
			label.Size = UDim2.new(1, 0, 0, 14)
			label.Position = UDim2.new(0, 6, 0, 1)
			label.BackgroundTransparency = 1
			label.Text = text .. ": " .. tostring(default)
			label.TextColor3 = Color3.fromRGB(200, 200, 200)
			label.Font = Enum.Font.Gotham
			label.TextSize = 12
			label.TextXAlignment = Enum.TextXAlignment.Left
			label.Parent = frame

			local sliderFrame = Instance.new("Frame")
			sliderFrame.Size = UDim2.new(1, -20, 0, 14)
			sliderFrame.Position = UDim2.new(0, 10, 0, 18)
			sliderFrame.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
			sliderFrame.BorderSizePixel = 0
			applyRoundedCorners(sliderFrame, 7)
			sliderFrame.Parent = frame

			local fill = Instance.new("Frame")
			fill.Size = UDim2.new(0, 0, 1, 0)
			fill.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
			fill.BorderSizePixel = 0
			applyRoundedCorners(fill, 7)
			fill.Parent = sliderFrame

			local thumb = Instance.new("TextButton")
			thumb.Size = UDim2.new(0, 14, 0, 14)
			thumb.Position = UDim2.new(0, 0, 0.5, -7)
			thumb.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
			thumb.BorderSizePixel = 0
			thumb.Text = ""
			applyRoundedCorners(thumb, 7)
			thumb.Parent = sliderFrame

			local value = default
			local function updateVisual(val)
				val = math.clamp(val, min, max)
				local percent = (val - min) / (max - min)
				fill.Size = UDim2.new(percent, 0, 1, 0)
				thumb.Position = UDim2.new(percent, -7, 0.5, -7)
				label.Text = text .. ": " .. string.format("%.2f", val)
			end
			updateVisual(default)

			local function setValueFromX(x)
				local sliderAbsPos = sliderFrame.AbsolutePosition.X
				local sliderWidth = sliderFrame.AbsoluteSize.X
				local relativeX = math.clamp(x - sliderAbsPos, 0, sliderWidth)
				local percent = relativeX / sliderWidth
				value = min + percent * (max - min)
				updateVisual(value)
				callback(value)
			end

			thumb.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					local moveConn, endConn
					moveConn = UserInputService.InputChanged:Connect(function(changedInput)
						if changedInput.UserInputType == Enum.UserInputType.MouseMovement or changedInput.UserInputType == Enum.UserInputType.Touch then
							setValueFromX(changedInput.Position.X)
						end
					end)
					endConn = UserInputService.InputEnded:Connect(function(endedInput)
						if endedInput.UserInputType == Enum.UserInputType.MouseButton1 or endedInput.UserInputType == Enum.UserInputType.Touch then
							moveConn:Disconnect()
							endConn:Disconnect()
						end
					end)
				end
			end)
			updateMainFrameHeight()
			return frame
		end

		-- Dropdown e MultiDropdown são mais complexos, mas seguem padrão similar (omitidos para brevidade, mas podem ser adicionados)
		-- Vou incluir versões completas dos elementos dentro da seção depois, mas por enquanto deixo assim.

		return Section
	end

